# ============================
# 건설 입찰 분석 시스템 환경설정
# .env.example → .env 로 복사 후 값 수정
# ============================

# PostgreSQL
POSTGRES_DB=biddb
POSTGRES_USER=biduser
POSTGRES_PASSWORD=bidpass123

# Redis
REDIS_PASSWORD=redispass123

# 앱 보안키 (랜덤 문자열로 변경 권장)
SECRET_KEY=changeme-super-secret-key-2024

# 초기 관리자 계정
FIRST_ADMIN_EMAIL=admin@bid.local
FIRST_ADMIN_PASSWORD=admin1234

# 나라장터 Open API 키 (공공데이터포털에서 발급)
# 없으면 데모 데이터로 동작
G2B_API_KEY=

# 자동 수집 활성화 (API 키 있을 때 true)
COLLECT_ENABLED=false

# 데모 데이터 자동 생성 (첫 실행 시 true 권장)
SEED_DEMO_DATA=true
