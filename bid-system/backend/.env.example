# 데이터베이스
DATABASE_URL=postgresql://biduser:bidpass123@localhost:5432/biddb

# Redis
REDIS_URL=redis://:redispass123@localhost:6379/0

# JWT — 반드시 변경 (32자 이상 랜덤 문자열)
SECRET_KEY=changeme-super-secret-key-2024
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 초기 관리자 계정
FIRST_ADMIN_EMAIL=admin@bid.local
FIRST_ADMIN_PASSWORD=admin1234

# CORS: "*" = 전체 허용, 프로덕션에서는 도메인 명시 (콤마 구분)
# 예: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# 나라장터 Open API (공공데이터포털 인증키)
NARA_API_KEY=

# 수집기 활성화 여부
COLLECT_ENABLED=false

# ML 모델 경로
ML_MODELS_PATH=/app/ml_models
MIN_TRAIN_SAMPLES=50

# 데모 데이터 시드 (개발: true, 프로덕션: false)
SEED_DEMO_DATA=true
