# ── 서비스 포트 (호스트 노출 포트) ──────────────────────────────
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
ML_API_PORT=8001
NOTIFIER_PORT=8003
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=stockuser
POSTGRES_PASSWORD=StrongPass123!
POSTGRES_DB=feature_stock
POSTGRES_DSN=postgresql+asyncpg://stockuser:StrongPass123!@postgres:5432/feature_stock

# ── KIS Open API (한국투자증권) ──────────────────────────────
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number
KIS_ACCOUNT_TYPE=01
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_WS_URL=ws://ops.koreainvestment.com:21000

# ── DART Open API ────────────────────────────────────────────
DART_API_KEY=your_dart_api_key_here

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── MinIO (모델 저장소) ──────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=MinioPass123!
MINIO_ENDPOINT=minio:9000

# ── 임베딩 모델 ──────────────────────────────────────────────
EMBEDDING_MODEL_NAME=jhgan/ko-sroberta-multitask
MODEL_CACHE_DIR=/models

# ── Collector 파라미터 ────────────────────────────────────────
TICK_FLUSH_SEC=5               # tick DB 배치 저장 간격(초)
MINUTE_INTERVAL_SEC=60         # 분봉 수집 간격(초)
SUPPLY_INTERVAL_SEC=1800       # 수급 수집 간격(초)
SUPPLY_BACKFILL_DAYS=130       # 수급 데이터 백필 영업일 수 (130 ≈ 6개월)
DAILY_BACKFILL_DAYS=260        # 일봉 백필 기간(거래일 기준 ~1년)
NEWS_INTERVAL_SEC=1800         # 뉴스 수집 간격(초, 기본 30분)

# ── 탐지 임계값 ──────────────────────────────────────────────
VOL_SURGE_RATIO=5.0            # 거래량 급증: 20일 평균 대비 배수
VOL_SURGE_MIN_AMOUNT=1000000000  # 거래대금 최소 기준(원, 기본 10억)
VOL_SURGE_SCORE_K=4.0          # 점수 민감도 계수
BREAKOUT_MIN_PCT=0.1           # 신고가 돌파 최소 초과율(%)
VI_RATE_PCT=10.0               # VI 탐지 변동률 기준(%)
VI_DEDUP_SEC=300               # VI 중복 억제 시간(초)
SUPPLY_SURGE_RATIO=5.0         # 수급 급증: 20일 평균 대비 배수
SUPPLY_DUAL_BUY_MIN_RATIO=2.0  # 외인+기관 동시 매수 최소 비율
CANDLE_LONG_WHITE_BODY_RATIO=0.65  # 장대양봉 몸통 비율 (0~1)
CANDLE_LONG_WHITE_MIN_CHANGE=3.0   # 장대양봉 최소 등락률 (%)
SENTIMENT_MODEL=snunlp/KR-FinBert-SC  # 감성 분석 모델 (HuggingFace 모델명)
USE_BERT_SENTIMENT=true        # false 로 설정 시 키워드 fallback 사용
SENTIMENT_POS_THR=0.15         # 뉴스 감성 긍정 판정 임계값
SENTIMENT_NEG_THR=-0.15        # 뉴스 감성 부정 판정 임계값
SIMILARITY_MIN_THRESHOLD=0.65  # 유사사례 벡터 최소 유사도 (0~1)
BACKTEST_COMMISSION=0.00015    # 백테스트 편도 수수료 (0.015%)
BACKTEST_SLIPPAGE=0.00100      # 백테스트 편도 슬리피지 (0.1%)
BACKTEST_SELL_TAX=0.00230      # 백테스트 증권거래세 (0.23%)

# ── 매매 추천 파라미터 ────────────────────────────────────────
REC_MIN_RISK_REWARD=2.0        # 최소 Risk/Reward 비율
REC_MAX_RISK=0.60              # 최대 허용 리스크 점수
REC_MIN_PROB=0.28              # 최소 성공확률 (0.28: 유사사례 하향 조정 고려)
REC_STOP_LOSS_PCT=0.05         # 기본 손절 비율(5%)
REC_TARGET_PCT=0.10            # 기본 목표 비율(10%)
REC_ENTRY_BAND=0.015           # 진입가 허용 밴드(±1.5%)
REC_VOL_HEAT_HIGH=20.0         # 거래량 과열 상한
REC_VOL_HEAT_MED=10.0          # 거래량 과열 중간
REC_CHG_HEAT_HIGH=15.0         # 변동률 과열 상한(%)
REC_CHG_HEAT_MED=10.0          # 변동률 과열 중간(%)
REC_ML_RISK_WEIGHT=0.45        # ML 리스크 가중치
REC_SIM_MAX_WEIGHT=0.40        # 유사사례 최대 가중치
REC_SIM_SCALE_N=25.0           # 유사사례 최대 가중치 도달 케이스 수

# ── 공시 분류 파라미터 ────────────────────────────────────────
USD_KRW_RATE=1400              # USD→KRW 환산율
DISCLOSURE_KW_WEIGHT=0.15      # 키워드 당 감성 점수 가중치
DISCLOSURE_POS_THR=0.25        # 호재 판정 임계값
DISCLOSURE_NEG_THR=-0.25       # 악재 판정 임계값

# ── ML 서비스 API ────────────────────────────────────────────
ML_SERVICE_URL=http://ml:8001   # recommender가 ML 추론 API를 호출하는 URL (비워두면 직접 로드)
ML_API_PORT=8001                # ML 서비스 내부 포트

# ── LightGBM 모델 파라미터 ────────────────────────────────────
LGBM_MODEL_DIR=/models/lgbm
LGBM_HOLD_SQUEEZE_DAYS=3       # BB 수축 시 보유기간
LGBM_VOL_HIGH_THRESH=15.0      # 거래량 과열 시 단기 보유
LGBM_HOLD_DEFAULT_DAYS=5       # 기본 보유기간
LGBM_RET_SCALE=20.0            # 기대수익률 스케일 계수
