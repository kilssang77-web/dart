{
  "title": "Quant Eye — ML Performance",
  "uid": "qe-ml",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Model AUC",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "fstock_ml_model_auc", "legendFormat": "AUC" }],
      "options": { "colorMode": "background", "thresholds": {
        "steps": [
          { "color": "red", "value": 0 },
          { "color": "yellow", "value": 0.6 },
          { "color": "green", "value": 0.7 }
        ]
      }}
    },
    {
      "id": 2, "type": "stat", "title": "Model F1",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "fstock_ml_model_f1", "legendFormat": "F1" }]
    },
    {
      "id": 3, "type": "stat", "title": "Optimal Threshold",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "fstock_ml_model_threshold", "legendFormat": "threshold" }]
    },
    {
      "id": 4, "type": "timeseries", "title": "Recommendation Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rate(fstock_recommendations_total[10m])", "legendFormat": "recs/min" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Feature Events Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "rate(fstock_feature_events_total[10m])", "legendFormat": "events/min" }]
    }
  ]
}
