# =============================================================================
# HARNESS
# =============================================================================

# 실행 로그 — 추적 불필요
.harness/phases/**/step*-stdout.log
.harness/phases/**/step*-review.json
.harness/phases/**/.guardrail_hash

# 외부 참조 레포 클론본 (등록 메타만 추적, summary.md는 팀 공유)
.harness/references/
!.harness/references/*/summary.md

# 캐시 / 임시 파일
.harness/*.cache
.harness/tmp/

# Python 바이트코드
.harness/scripts/__pycache__/
.harness/scripts/*.pyc
.harness/scripts/*.pyo

# =============================================================================
