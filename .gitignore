# =============================================================================
# HARNESS
# =============================================================================

# 실행 로그 — 추적 불필요
.harness/phases/**/step*-stdout.log
.harness/phases/**/step*-review.json
.harness/phases/**/.guardrail_hash

# 외부 참조 레포 클론본 (등록 메타만 추적, summary.md는 팀 공유)
.harness/references/
!.harness/references/*/summary.md

# 캐시 / 임시 파일
.harness/*.cache
.harness/tmp/

# Python 바이트코드
.harness/scripts/__pycache__/
.harness/scripts/*.pyc
.harness/scripts/*.pyo

# =============================================================================
# SECRETS & ENV
# =============================================================================
.env
.env.*
!.env.example
!.env.*.example

# =============================================================================
# JAVA / SPRING BOOT
# =============================================================================

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# Spring Boot executable jar
*.jar
!gradle/wrapper/gradle-wrapper.jar

# Spring Boot devtools restart trigger
.spring-boot-devtools.properties

# Log files
*.log
logs/
spring.log

