{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)",
      "Agent(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__filesystem__*",
      "mcp__memory__*",
      "mcp__ide__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "ScheduleWakeup(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "CronList(*)",
      "Skill(*)",
      "AskUserQuestion(*)",
      "NotebookEdit(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/a2m/atom-harness-g2b/.harness/scripts/guard_bash.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/a2m/atom-harness-g2b/.harness/scripts/guard_paths.py \"$CLAUDE_TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/a2m/atom-harness-g2b/.harness/scripts/guard_json.py \"$CLAUDE_TOOL_INPUT\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/a2m/atom-harness-g2b/.harness/scripts/run_checks.py"
          }
        ]
      }
    ]
  }
}
